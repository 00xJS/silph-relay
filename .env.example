# ── X auth (required — set on the RSSHub side) ───────────────────────────────
# RSSHub's twitter routes need the auth_token cookie of ONE burner X account.
# Log in to X with a THROWAWAY account (never your personal one), then DevTools
# → Application → Cookies → copy the auth_token value.
# In the co-located Docker/Render setup this env var is read by RSSHub itself.
TWITTER_AUTH_TOKEN=YOUR_BURNER_AUTH_TOKEN

# ── RSSHub ───────────────────────────────────────────────────────────────────
# Co-located container default; point at any reachable instance for local runs.
RSSHUB_URL=http://127.0.0.1:1200
RSSHUB_PORT=1200
CACHE_EXPIRE=30

# ── Discord webhooks (required) ──────────────────────────────────────────────
# updates → main relay channel (PokemonGoApp, LeekDuck, thepokemodgroup)
# drops   → #drops-alerts channel (PokemonDealsTCG)
DISCORD_WEBHOOK_UPDATES=https://discord.com/api/webhooks/YOUR_UPDATES_ID/YOUR_TOKEN
DISCORD_WEBHOOK_DROPS=https://discord.com/api/webhooks/YOUR_DROPS_ID/YOUR_TOKEN

# ── Poll cadence ─────────────────────────────────────────────────────────────
# Fast path (combined-search feed) runs every cycle; per-account sweep every
# SWEEP_INTERVAL. Keep POLL_INTERVAL_SECONDS >= 40 on one token.
POLL_INTERVAL_SECONDS=45
SWEEP_INTERVAL_SECONDS=300
POLL_JITTER_SECONDS=15
# If the search route is down, sweeps auto-speed-up to this cadence instead
SWEEP_INTERVAL_DEGRADED_SECONDS=120

# ── Runtime ──────────────────────────────────────────────────────────────────
PORT=10000
RUN_ONCE=0                      # 1 = single pass then exit (local test / CI)
# PRIME_ON_EMPTY=1             # fresh install: mark existing tweets seen

# ── seen_ids persistence (recommended on Render free tier) ───────────────────
# Render's free filesystem is ephemeral; mirror seen IDs to the repo so a
# restart doesn't repost. Fine-grained PAT with Contents: Read/Write.
# GITHUB_TOKEN=
# GITHUB_REPO=00xJS/silph-relay
# GITHUB_BRANCH=main
# GITHUB_SEEN_IDS_PATH=data/seen_ids.json
